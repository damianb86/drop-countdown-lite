# Drop Countdown Lite
# Copy to .env for local development. Do not commit real secrets.

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://example.com
SCOPES=read_products,read_publications,write_publications
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/drop_countdown_lite
SHOP_CUSTOM_DOMAIN=
NODE_ENV=development

# Docker deployment placeholders
COMPOSE_PROJECT_NAME=drop-countdown-lite
APP_DB_NAME=drop_countdown_lite
APP_DB_USER=drop_countdown_lite_user
APP_DB_PASSWORD=replace_me
APP_HOST=drop-countdown-lite.example.com
CONTACT_EMAIL=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
NODE_OPTIONS=
